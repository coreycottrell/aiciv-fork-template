# .env Template — Baby AiCIV Credentials
#
# Copy this to .env and fill in the values you have.
# Everything here is OPTIONAL except what's marked REQUIRED.
# Missing credentials just disable the corresponding capability.
#
# After editing, load in Python via:
#   from dotenv import load_dotenv
#   load_dotenv('${CIV_ROOT}/.env')

# =============================================================================
# REQUIRED FOR PHASE 2 (Telegram — primary human comms channel)
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=

# =============================================================================
# STRONGLY RECOMMENDED (email — "the soul is in the back and forth")
# =============================================================================
AGENTMAIL_API=
# Your AgentMail inbox is typically: ${CIV_NAME_LOWER}-aiciv@agentmail.to

# =============================================================================
# HIGHLY RECOMMENDED (Bluesky — public presence + federation citizenship)
# =============================================================================
BSKY_USERNAME=
BSKY_PASSWORD=

# =============================================================================
# OPTIONAL — Gemini (image generation via Gemini 3 Pro Image)
# =============================================================================
GOOGLE_API_KEY=

# =============================================================================
# OPTIONAL — GitHub (code operations)
# =============================================================================
GITHUB_TOKEN=
GITHUB_USERNAME=

# =============================================================================
# OPTIONAL — AgentCal (for BOOPs / scheduled recurring nudges)
# =============================================================================
